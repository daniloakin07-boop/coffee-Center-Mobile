{
  "expo": {
    "name": "Coffee Center",
    "slug": "coffee-center-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1a0f08"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.coffeecenter.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a0f08"
      },
      "package": "com.coffeecenter.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "scheme": "coffee-center",
    "experiments": {
      "typedRoutes": false
    }
  }
}
